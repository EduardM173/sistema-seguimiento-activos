# ══════════════════════════════════════════════════════════════════════════════
# GraphRAG Backend Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── Google Gemini API (REQUIRED) ──────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── PostgreSQL (defaults work with docker-compose) ────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=graphrag
POSTGRES_USER=graphrag
POSTGRES_PASSWORD=graphrag_secret

# ── Neo4j (defaults work with docker-compose) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag_secret

# ── Jira Integration (OPTIONAL) ───────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_TOKEN=your-jira-api-token

# ── Application Settings ──────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Model Configuration ───────────────────────────────────────────────────────
EMBEDDING_MODEL=models/text-embedding-004
LLM_MODEL=models/gemini-1.5-pro
LLM_TEMPERATURE=0.0

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── DSL Reasoning Engine ──────────────────────────────────────────────────────
DSL_MAX_DEDUCTION_STEPS=100
DSL_SIMPLIFY_BEFORE_ANSWER=true
